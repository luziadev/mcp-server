{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.luziadev/luzia",
  "displayName": "Luzia Crypto Prices",
  "description": "Real-time crypto prices from Binance, Coinbase, Kraken, OKX, and Bybit",
  "version": "1.2.2",
  "author": {
    "name": "Luzia",
    "email": "hello@luzia.dev",
    "url": "https://luzia.dev"
  },
  "repository": {
    "url": "https://github.com/luziadev/mcp-server",
    "source": "github"
  },
  "license": "MIT",
  "homepage": "https://luzia.dev",
  "categories": ["finance", "cryptocurrency", "pricing"],
  "keywords": [
    "crypto",
    "cryptocurrency",
    "bitcoin",
    "ethereum",
    "binance",
    "coinbase",
    "trading",
    "prices",
    "ticker",
    "exchange"
  ],
  "installation": {
    "npm": {
      "package": "@luziadev/mcp-server",
      "command": "npx",
      "args": ["-y", "@luziadev/mcp-server", "--stdio"]
    }
  },
  "configuration": {
    "required": [
      {
        "name": "LUZIA_API_KEY",
        "description": "Your Luzia API key for authentication",
        "type": "string",
        "secret": true
      }
    ],
    "optional": [
      {
        "name": "LUZIA_API_URL",
        "description": "Luzia API base URL",
        "type": "string",
        "default": "https://api.luzia.dev"
      },
      {
        "name": "MCP_PORT",
        "description": "HTTP server port (for HTTP/SSE mode)",
        "type": "number",
        "default": 50060
      },
      {
        "name": "LOG_LEVEL",
        "description": "Logging level",
        "type": "string",
        "enum": ["trace", "debug", "info", "warn", "error"],
        "default": "info"
      }
    ]
  },
  "tools": [
    {
      "name": "get_ticker",
      "description": "Get current price for a specific trading pair on an exchange",
      "inputSchema": {
        "type": "object",
        "properties": {
          "exchange": {
            "type": "string",
            "description": "Exchange identifier (e.g., 'binance', 'coinbase')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair symbol (e.g., 'BTC/USDT', 'ETH/USD')"
          }
        },
        "required": ["exchange", "symbol"]
      }
    },
    {
      "name": "get_tickers",
      "description": "Get prices for multiple trading pairs or all pairs on an exchange",
      "inputSchema": {
        "type": "object",
        "properties": {
          "exchange": {
            "type": "string",
            "description": "Exchange identifier"
          },
          "symbols": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional list of trading pair symbols"
          }
        },
        "required": ["exchange"]
      }
    },
    {
      "name": "get_exchanges",
      "description": "List all supported cryptocurrency exchanges and their current status",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_markets",
      "description": "List all available trading pairs on a specific exchange",
      "inputSchema": {
        "type": "object",
        "properties": {
          "exchange": {
            "type": "string",
            "description": "Exchange identifier"
          }
        },
        "required": ["exchange"]
      }
    },
    {
      "name": "get_history",
      "description": "Get historical OHLCV (Open, High, Low, Close, Volume) candlestick data for a cryptocurrency trading pair. Returns time-series candle data useful for technical analysis, charting, and trend detection.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "exchange": {
            "type": "string",
            "description": "Exchange to fetch history from (e.g., 'binance', 'coinbase', 'kraken')"
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair symbol in normalized format (e.g., 'BTC/USDT', 'ETH/USD')"
          },
          "interval": {
            "type": "string",
            "description": "Candle interval (default: '1h')",
            "enum": ["1m", "5m", "15m", "1h", "1d"]
          },
          "start": {
            "type": "number",
            "description": "Start timestamp in Unix milliseconds (default: 24h ago)"
          },
          "end": {
            "type": "number",
            "description": "End timestamp in Unix milliseconds (default: now)"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of candles to return (default: 300, max: 500)"
          }
        },
        "required": ["exchange", "symbol"]
      }
    }
  ],
  "prompts": [
    {
      "name": "analyze_price_movement",
      "description": "Analyze recent price movements and trends for a cryptocurrency trading pair",
      "arguments": [
        {
          "name": "exchange",
          "description": "Exchange to analyze",
          "required": true
        },
        {
          "name": "symbol",
          "description": "Trading pair to analyze",
          "required": true
        }
      ]
    },
    {
      "name": "compare_exchanges",
      "description": "Compare prices for a trading pair across multiple exchanges to find arbitrage opportunities",
      "arguments": [
        {
          "name": "symbol",
          "description": "Trading pair to compare",
          "required": true
        }
      ]
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@luziadev/mcp-server",
      "version": "1.2.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "LUZIA_API_KEY",
          "description": "Your Luzia API key (lz_ prefix)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "transports": ["stdio", "http"],
  "runtimeRequirements": {
    "node": ">=20.0.0"
  }
}
